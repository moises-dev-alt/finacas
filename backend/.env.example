# Stripe (configure os valores reais apenas nas variaveis protegidas da Netlify)
STRIPE_SECRET_KEY=SUBSTITUA_PELA_CHAVE_SECRETA_DA_STRIPE
STRIPE_WEBHOOK_SECRET=SUBSTITUA_PELO_SEGREDO_DO_WEBHOOK_DA_STRIPE
STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/SEU_PAYMENT_LINK

# Firebase Admin
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-exemplo@seu-projeto-firebase.iam.gserviceaccount.com
# Cole o campo private_key completo do JSON, mantendo os \n escapados.
FIREBASE_PRIVATE_KEY="SUBSTITUA_PELO_CAMPO_PRIVATE_KEY_DO_JSON"

# Trial Pro automatico para contas criadas a partir deste instante (ISO/UTC)
PRO_TRIAL_ELIGIBLE_SINCE=2026-07-14T21:08:19.000Z

# Aplicacao e CORS
APP_URL=https://seu-site.web.app
FRONTEND_ORIGINS=http://localhost:5173,https://seu-site.web.app

# Opcional: UIDs do Firebase Auth autorizados a usar rotas administrativas
ADMIN_UIDS=uid_admin_1,uid_admin_2
